rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper Functions
    // =========================================================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is accessing their own data
    function isUserSelf(userId) {
      return request.auth.uid == userId;
    }

    // Validate user profile data
    function isValidUserProfile() {
      let data = request.resource.data;
      return data.keys().hasAll(['email', 'displayName', 'createdAt']) &&
             data.email is string &&
             data.displayName is string;
    }

    // Validate journal entry data
    function isValidJournalEntry() {
      let data = request.resource.data;
      return data.keys().hasAll(['date', 'entry']) &&
             data.date is string &&
             data.entry is string &&
             data.entry.size() <= 1000;
    }

    // Validate favorite data
    function isValidFavorite() {
      let data = request.resource.data;
      return data.keys().hasAll(['imageUrl', 'savedAt']) &&
             data.imageUrl is string;
    }

    // Validate pet data
    function isValidPet() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'status']) &&
             data.name is string &&
             data.status in ['active', 'memorial'];
    }

    // =========================================================================
    // User Documents
    // =========================================================================

    match /users/{userId} {
      // Users can read and write their own profile
      allow read: if isUserSelf(userId);
      allow create: if isUserSelf(userId) && isValidUserProfile();
      allow update: if isUserSelf(userId);
      allow delete: if isUserSelf(userId);

      // Journal Entries (subcollection)
      match /journal/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidJournalEntry();
        allow update: if isOwner(userId) && isValidJournalEntry();
        allow delete: if isOwner(userId);
      }

      // Favorites (subcollection)
      match /favorites/{favoriteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFavorite();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Pets (subcollection)
      match /pets/{petId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidPet();
        allow update: if isOwner(userId) && isValidPet();
        allow delete: if isOwner(userId);
      }

      // Tamagotchi State (subcollection)
      match /tamagotchi/{petId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Friends (subcollection)
      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isUserSelf(friendId);
        allow delete: if isOwner(userId);
      }

      // Posts (subcollection)
      match /posts/{postId} {
        // Users can read their own posts
        allow read: if isOwner(userId);

        // Users can create posts on their own profile
        allow create: if isOwner(userId) &&
                        request.resource.data.authorUid == userId;

        // Users can update/delete their own posts
        allow update, delete: if isOwner(userId) &&
                                 resource.data.authorUid == userId;
      }
    }

    // =========================================================================
    // Public Posts Feed (for social features)
    // =========================================================================

    match /posts/{postId} {
      // Anyone authenticated can read public posts
      allow read: if isAuthenticated();

      // Users can create posts
      allow create: if isAuthenticated() &&
                      request.resource.data.authorUid == request.auth.uid;

      // Users can update/delete their own posts
      allow update, delete: if isAuthenticated() &&
                               resource.data.authorUid == request.auth.uid;
    }

    // =========================================================================
    // Activity Feed (denormalized for performance)
    // =========================================================================

    match /feed/{userId}/{activityId} {
      // Users can only read their own feed
      allow read: if isUserSelf(userId);

      // Only server-side Cloud Functions can write to feeds
      // This prevents users from injecting fake activities
      allow write: if false;
    }

    // =========================================================================
    // Community Groups (breed-specific, regional, etc.)
    // =========================================================================

    match /groups/{groupId} {
      // Anyone authenticated can read group info
      allow read: if isAuthenticated();

      // Only admins can create/update/delete groups
      // (This would be managed through Cloud Functions or Firebase Admin SDK)
      allow create, update, delete: if false;

      // Group posts
      match /posts/{postId} {
        // Members can read group posts
        allow read: if isAuthenticated();

        // Members can create posts in groups they belong to
        allow create: if isAuthenticated() &&
                        request.resource.data.authorUid == request.auth.uid;

        // Users can update/delete their own posts
        allow update, delete: if isAuthenticated() &&
                                 resource.data.authorUid == request.auth.uid;
      }

      // Group members
      match /members/{userId} {
        allow read: if isAuthenticated();
        allow create: if isUserSelf(userId);
        allow delete: if isUserSelf(userId);
      }
    }

    // =========================================================================
    // Memorial Tributes (public memorials)
    // =========================================================================

    match /memorials/{memorialId} {
      // Anyone can read public memorials
      allow read: if isAuthenticated();

      // Users can create memorials for their pets
      allow create: if isAuthenticated() &&
                      request.resource.data.ownerUid == request.auth.uid;

      // Users can update/delete their own memorials
      allow update, delete: if isAuthenticated() &&
                               resource.data.ownerUid == request.auth.uid;

      // Memorial tributes/comments
      match /tributes/{tributeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAuthenticated() &&
                        resource.data.authorUid == request.auth.uid;
      }
    }

    // =========================================================================
    // Notifications
    // =========================================================================

    match /notifications/{userId}/{notificationId} {
      // Users can only read their own notifications
      allow read: if isUserSelf(userId);

      // Users can mark their own notifications as read
      allow update: if isUserSelf(userId) &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['read', 'readAt']);

      // Only Cloud Functions can create notifications
      allow create, delete: if false;
    }

    // =========================================================================
    // Default: Deny all other access
    // =========================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
